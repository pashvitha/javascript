// 1. Function to return sum of two numbers
function sum(a, b) {
    return a + b;
}
console.log("Sum:", sum(5, 3));


// 2. Function to print string in uppercase
function printUpperCase(str) {
    console.log("Uppercase:", str.toUpperCase());
}
printUpperCase("hello");


// 3. Passing undefined to a function
function showValue(value) {
    console.log("Value passed:", value);
}
showValue(undefined); // undefined


// 4. Function to check if array is empty
function checkArray(arr) {
    if (arr.length === 0) {
        console.log("Array is empty");
    } else {
        console.log("Array is not empty");
    }
}
checkArray([]);
checkArray([10, 20]);


// 5. Function to return difference of two numbers
function difference(a, b) {
    return a - b;
}
console.log("Difference:", difference(10, 4));


// 6. Function for greeting with name and age
function greet(name, age) {
    return `Hello, ${name}! You are ${age} years old.`;
}
console.log(greet("Pashvitha", 21));


// 7. Function to check even number
function isEven(num) {
    return num % 2 === 0;
}
console.log("Is 4 even?", isEven(4));
console.log("Is 7 even?", isEven(7));
