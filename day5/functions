
// 1. Function to return sum of two numbers
function sum(a, b) {
    return a + b;
}
console.log("Sum:", sum(5, 3));


// 2. Function to print string in uppercase
function printUpperCase(str) {
    console.log(str.toUpperCase());
}
printUpperCase("hello");


// 3. What happens if undefined is passed
function checkUndefined(value) {
    if (value === undefined) {
        console.log("Value is undefined");
    } else {
        console.log("Value:", value);
    }
}
checkUndefined(undefined);


// 4. Function to check if array is empty
function isArrayEmpty(arr) {
    if (arr.length === 0) {
        return true;
    } else {
        return false;
    }
}
console.log("Is array empty?", isArrayEmpty([]));
console.log("Is array empty?", isArrayEmpty([1, 2]));


// 5. Function to return difference
function difference(a, b) {
    return a - b;
}
console.log("Difference:", difference(10, 4));


// 6. Greeting function
function greet(name, age) {
    return "Hello, " + name + "! You are " + age + " years old.";
}
console.log(greet("Pashvitha", 21));


// 7. Function to check even number
function isEven(num) {
    return num % 2 === 0;
}
console.log("4 is even?", isEven(4));
console.log("7 is even?", isEven(7));
